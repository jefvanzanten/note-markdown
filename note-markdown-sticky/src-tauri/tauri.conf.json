{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "note-markdown-sticky",
  "version": "0.1.0",
  "identifier": "com.example.note-markdown-sticky",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sticky",
        "label": "main",
        "width": 380,
        "height": 430,
        "minWidth": 300,
        "minHeight": 260,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
