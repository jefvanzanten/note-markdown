{
  "name": "note-markdown-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "tauri",
    "android:build": "tauri android build --target aarch64",
    "android:install": "tauri android build --target aarch64 --debug && adb install src-tauri/gen/android/app/build/outputs/apk/universal/debug/app-universal-debug.apk",
    "android:dev": "tauri android dev"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tauri-apps/cli": "^2",
    "@types/node": ">=20",
    "@tsconfig/svelte": "^5.0.4",
    "svelte": "^4.2.18",
    "svelte-check": "^3.8.6",
    "tslib": "^2.6.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  },
  "dependencies": {
    "@note/shared-api": "workspace:*",
    "@note/shared-editor": "workspace:*",
    "@note/shared-state": "workspace:*",
    "@note/shared-types": "workspace:*",
    "@note/shared-utils": "workspace:*"
  }
}
