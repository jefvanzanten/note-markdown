{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "note-web-tray",
  "version": "0.1.0",
  "identifier": "com.example.note-web-tray",
  "build": {
    "beforeDevCommand": "pnpm --filter web-app run build",
    "beforeBuildCommand": "pnpm --filter web-app run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
