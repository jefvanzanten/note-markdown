{
  "name": "note-markdown-workspace",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "note-markdown-client",
    "note-markdown-sticky",
    "shared/*"
  ],
  "scripts": {
    "check": "npm run check --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "note-sticky:dev": "npm run -w note-markdown-sticky tauri -- dev",
    "note-sticky:build": "npm run -w note-markdown-sticky tauri -- build"
  }
}
